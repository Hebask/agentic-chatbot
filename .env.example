APP_NAME=Agentic Chatbot
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000

DATABASE_URL=sqlite:///./agentic_chatbot.db

OPENAI_API_KEY=your_api_key_here
